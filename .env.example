# Sanity CMS
# Get these from sanity.io → your project → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Resend (email)
# Get from resend.com → API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@justacoustics.co

# Google Analytics 4
# Get from analytics.google.com → your property → Data Streams → Measurement ID
NEXT_PUBLIC_GA_ID=
